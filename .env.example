# Copy this file to .env and fill in real values.
# Do not commit .env.

# ---------------------------------------------------------------------------
# Telegram bot pool
# ---------------------------------------------------------------------------

# Bot A: default Expedition MentorBot.
BOT_A_TOKEN=1234567890:replace-with-mentor-bot-token
BOT_A_USERNAME=@YourMentorBot

# Bot B: default Expedition ScholarBot.
BOT_B_TOKEN=1234567890:replace-with-scholar-bot-token
BOT_B_USERNAME=@YourScholarBot

# Bot C: default Expedition StageControllerBot.
BOT_C_TOKEN=1234567890:replace-with-controller-bot-token
BOT_C_USERNAME=@YourControllerBot

# Bot D: default Expedition ScoutBot.
BOT_D_TOKEN=1234567890:replace-with-scout-bot-token
BOT_D_USERNAME=@YourScoutBot

# Optional Expedition actor bots.
BOT_E_TOKEN=1234567890:replace-with-recorder-bot-token
BOT_E_USERNAME=@YourRecorderBot

BOT_F_TOKEN=1234567890:replace-with-guide-bot-token
BOT_F_USERNAME=@YourGuideBot

# Expedition role mapping. Only the controller profile needs polling.
# Actor profiles are used by the controller runtime to send role messages.
EXPEDITION_CONTROLLER_PROFILE=C
EXPEDITION_MENTOR_PROFILE=A
EXPEDITION_SCHOLAR_PROFILE=B
EXPEDITION_SCOUT_PROFILE=D
EXPEDITION_LOG_PROFILE=E
EXPEDITION_GUIDE_PROFILE=F

# ---------------------------------------------------------------------------
# Codex / Responses API
# ---------------------------------------------------------------------------

CODEX_BASE_URL=https://ai-internal.orionarm.ai
CODEX_API_KEY=replace-with-codex-api-key
CODEX_MODEL=gpt-5.5
CODEX_EXTRACT_MODEL=gpt-5.5

# ---------------------------------------------------------------------------
# Optional behavior
# ---------------------------------------------------------------------------

# Number of user/assistant turns kept for ordinary private chat context.
BOT_HISTORY_TURNS=8

# ---------------------------------------------------------------------------
# Optional storage overrides
# ---------------------------------------------------------------------------
# By default, each profile gets separate local files:
#   data/telegram_persistence_c.pickle
#   data/bot_memory_c.sqlite3
#
# Uncomment only if you want custom paths.

# TELEGRAM_PERSISTENCE_FILE=data/telegram_persistence.pickle
# BOT_MEMORY_DB=data/bot_memory.sqlite3

# BOT_C_PERSISTENCE_FILE=data/telegram_persistence_c.pickle
# BOT_C_MEMORY_DB=data/bot_memory_c.sqlite3
