# Copy this file to .env and fill in real values.
# Do not commit .env.

# ---------------------------------------------------------------------------
# Telegram bots
# ---------------------------------------------------------------------------

# Bot A: CalendarBot
BOT_A_TOKEN=1234567890:replace-with-calendar-bot-token
BOT_A_USERNAME=@YourCalendarBot

# Bot B: WeatherBot
BOT_B_TOKEN=1234567890:replace-with-weather-bot-token
BOT_B_USERNAME=@YourWeatherBot

# Bot C: OrchestratorBot
BOT_C_TOKEN=1234567890:replace-with-orchestrator-bot-token
BOT_C_USERNAME=@YourOrchestratorBot

# Bot D: SlotMatcherBot
BOT_D_TOKEN=1234567890:replace-with-slot-matcher-bot-token
BOT_D_USERNAME=@YourSlotMatcherBot

# Role mapping. Defaults are A/B/C/D, but keeping them explicit is clearer.
ORCHESTRATOR_PROFILE=C
CALENDAR_BOT_PROFILE=A
WEATHER_BOT_PROFILE=B
SLOT_MATCHER_BOT_PROFILE=D

# ---------------------------------------------------------------------------
# Codex / Responses API
# ---------------------------------------------------------------------------

CODEX_BASE_URL=https://ai-internal.orionarm.ai
CODEX_API_KEY=replace-with-codex-api-key
CODEX_MODEL=gpt-5.5
CODEX_EXTRACT_MODEL=gpt-5.5

# ---------------------------------------------------------------------------
# Optional behavior
# ---------------------------------------------------------------------------

# Number of user/assistant turns kept for ordinary chat context.
BOT_HISTORY_TURNS=8

# ---------------------------------------------------------------------------
# Optional storage overrides
# ---------------------------------------------------------------------------
# By default, each profile gets separate local files:
#   data/telegram_persistence_a.pickle
#   data/bot_memory_a.sqlite3
#   data/bot_schedule_a.sqlite3
#
# Uncomment only if you want custom paths.

# TELEGRAM_PERSISTENCE_FILE=data/telegram_persistence.pickle
# BOT_MEMORY_DB=data/bot_memory.sqlite3
# BOT_SCHEDULE_DB=data/bot_schedule.sqlite3

# BOT_A_PERSISTENCE_FILE=data/telegram_persistence_a.pickle
# BOT_A_MEMORY_DB=data/bot_memory_a.sqlite3
# BOT_A_SCHEDULE_DB=data/bot_schedule_a.sqlite3

# BOT_B_PERSISTENCE_FILE=data/telegram_persistence_b.pickle
# BOT_B_MEMORY_DB=data/bot_memory_b.sqlite3
# BOT_B_SCHEDULE_DB=data/bot_schedule_b.sqlite3

# BOT_C_PERSISTENCE_FILE=data/telegram_persistence_c.pickle
# BOT_C_MEMORY_DB=data/bot_memory_c.sqlite3
# BOT_C_SCHEDULE_DB=data/bot_schedule_c.sqlite3

# BOT_D_PERSISTENCE_FILE=data/telegram_persistence_d.pickle
# BOT_D_MEMORY_DB=data/bot_memory_d.sqlite3
# BOT_D_SCHEDULE_DB=data/bot_schedule_d.sqlite3
